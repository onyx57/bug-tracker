# Use official Go image as base
FROM golang:1.23-bullseye

# Set labels for better container management
LABEL maintainer="bug-tracker-team"
LABEL description="Docker agent with Go and JUnit for CI/CD pipeline"
LABEL version="1.0"

# Install essential tools and Java (for JUnit)
RUN apt-get update && apt-get install -y \
    openjdk-17-jdk \
    wget \
    unzip \
    curl \
    git \
    make \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Set JAVA_HOME and update PATH
ENV JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
ENV PATH=$JAVA_HOME/bin:$PATH

# Install Go tools commonly used in CI/CD
RUN go install github.com/jstemmer/go-junit-report/v2@v2.1.0 && \
    go install github.com/golangci/golangci-lint/cmd/golangci-lint@v1.54.2 && \
    go install golang.org/x/tools/cmd/goimports@v0.13.0

# Install JUnit and Maven for Java testing
RUN mkdir -p /opt/junit && \
    wget -O /opt/junit/junit-platform-console-standalone.jar \
    https://repo1.maven.org/maven2/org/junit/platform/junit-platform-console-standalone/1.10.2/junit-platform-console-standalone-1.10.2.jar

# Install Maven for Java dependency management
RUN wget -O /tmp/maven.tar.gz \
    https://archive.apache.org/dist/maven/maven-3/3.9.5/binaries/apache-maven-3.9.5-bin.tar.gz && \
    tar -xzf /tmp/maven.tar.gz -C /opt && \
    ln -s /opt/apache-maven-3.9.5 /opt/maven && \
    rm /tmp/maven.tar.gz

# Set Maven environment
ENV MAVEN_HOME=/opt/maven
ENV PATH=$MAVEN_HOME/bin:$PATH

# Create a non-root user for security
RUN useradd -m -s /bin/bash jenkins && \
    usermod -aG sudo jenkins && \
    mkdir -p /go/pkg && \
    chown -R jenkins:jenkins /go

# Set working directory
WORKDIR /workspace

# Change ownership of workspace to jenkins user
RUN chown -R jenkins:jenkins /workspace

# Switch to jenkins user
USER jenkins

# Set Go environment for jenkins user
ENV GOCACHE=/home/jenkins/.cache/go-build
ENV GOMODCACHE=/home/jenkins/go/pkg/mod

# Default command
CMD ["/bin/bash"]
